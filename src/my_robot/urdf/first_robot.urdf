<?xml version="1.0"?>
<!-- Define the root node of the robot, named first_robot -->
<robot name="first_robot">

    <!-- ================= Link 1: Base (base_link) ================= -->
    <link name="base_link">
        <!-- Visual properties: used for displaying in RViz/Gazebo -->
        <visual>
            <geometry>
                <!-- Shape: cylinder with radius 0.1m and length 0.05m -->
                <cylinder radius="0.1" length="0.05"/>
            </geometry>
            <!-- Set color to blue (RGBA) -->
            <material name="blue">
                <color rgba="0.0 0.0 1.0 1.0"/>
            </material>
        </visual>
        
        <!-- Collision properties: used for physics engine collision calculation -->
        <collision>
            <geometry>
                <cylinder radius="0.1" length="0.05"/>
            </geometry>
        </collision>
        
        <!-- Inertial properties: used for dynamic simulation, mass set to 2kg -->
        <inertial>
            <mass value="2.0"/>
            <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
        </inertial>
    </link>

    <!-- ================= Link 2: Arm (arm_link) ================= -->
    <link name="arm_link">
        <visual>
            <geometry>
                <!-- Shape: box with size 0.3m x 0.05m x 0.05m -->
                <box size="0.3 0.05 0.05"/>
            </geometry>
            <!-- Set color to red -->
            <material name="red">
                <color rgba="1.0 0.0 0.0 1.0"/>
            </material>
        </visual>
        
        <collision>
            <geometry>
                <box size="0.3 0.05 0.05"/>
            </geometry>
        </collision>
        
        <inertial>
            <mass value="1.0"/>
            <inertia ixx="0.005" ixy="0.0" ixz="0.0" iyy="0.005" iyz="0.0" izz="0.005"/>
        </inertial>
    </link>

    <!-- ================= Joint: Connects base and arm ================= -->
    <joint name="base_to_arm_joint" type="revolute">
        <!-- Parent link -->
        <parent link="base_link"/>
        <!-- Child link -->
        <child link="arm_link"/>
        
        <!-- Joint origin and offset: set at the top of the base, slightly offset along X-axis -->
        <origin xyz="0.05 0.0 0.025" rpy="0.0 0.0 0.0"/>
        
        <!-- Rotation axis: rotates around Z-axis -->
        <axis xyz="0.0 0.0 1.0"/>
        
        <!-- Motion limits: restricts rotation angle (approx -90 to +90 deg), max effort, and velocity -->
        <limit lower="-1.57" upper="1.57" effort="100.0" velocity="1.0"/>
    </joint>

</robot>